PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/skylearn
NODE_ENV=development

# Origins allowed to call the API (comma-separated)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174

# Backend public base URL (used for OAuth callback fallback)
BASE_URL=http://localhost:5000

# Frontend URL for OAuth redirects
FRONTEND_URL=http://localhost:5173

# Auth
JWT_SECRET=change-this-to-a-long-random-secret-min-32-chars
JWT_EXPIRES_IN=7d
SESSION_SECRET=change-this-session-secret-min-32-chars

# Google OAuth  (create at https://console.cloud.google.com)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
# Full callback URL (optional — overrides BASE_URL fallback)
# GOOGLE_REDIRECT_URI=http://localhost:5000/api/auth/google/callback
